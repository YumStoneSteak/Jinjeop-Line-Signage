{
  "name": "jinjeop-line-signage",
  "version": "2.1.0",
  "description": "Jinjeop Line Signage Electron app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "verify:maintenance": "node scripts/verify-maintenance.js",
    "build": "electron-builder --win nsis",
    "build:nsis": "electron-builder --win nsis"
  },
  "build": {
    "appId": "kr.or.ncuc.jinjeop-line-signage",
    "productName": "Jinjeop Line Signage",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "icon": "files/icons/ncuc.ico",
    "win": {
      "icon": "files/icons/ncuc.ico",
      "executableName": "Jinjeop Line Signage",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Jinjeop Line Signage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YumStoneSteak",
        "repo": "Jinjeop-Line-Signage",
        "releaseType": "release"
      }
    ],
    "extraFiles": [
      {
        "from": "files",
        "to": "files",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "keywords": [
    "electron",
    "slideshow",
    "signage"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
