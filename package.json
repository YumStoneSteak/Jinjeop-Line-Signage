{
  "name": "jinjeop-line-signage",
  "version": "2.0.1",
  "description": "Jinjeop Line Signage Electron app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\run-dashboard-local.ps1",
    "prepare:local": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\run-dashboard-local.ps1 -NoLaunch",
    "watchdog": "node launcher.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "kr.or.ncuc.jinjeop-line-signage",
    "productName": "Jinjeop Line Signage",
    "artifactName": "${productName} ${version}.${ext}",
    "icon": "files/icons/ncuc.ico",
    "win": {
      "icon": "files/icons/ncuc.ico",
      "executableName": "Jinjeop Line Signage",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Jinjeop Line Signage"
    },
    "extraFiles": [
      {
        "from": "files",
        "to": "files",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "keywords": [
    "electron",
    "slideshow",
    "signage"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1"
  }
}
